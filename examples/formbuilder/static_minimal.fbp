<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<wxFormBuilder_Project>
  <object class="Project" name="App">
    <object class="wxFrame" name="MainFrame">
      <property name="title">Demo</property>
      <property name="size">500,300</property>
      <object class="wxStaticText" name="lblHello">
        <property name="label">Hello</property>
        <property name="pos">20,20</property>
      </object>
      <object class="wxButton" name="btnOk">
        <property name="label">OK</property>
        <property name="pos">20,60</property>
        <property name="size">90,30</property>
      </object>
    </object>
  </object>
</wxFormBuilder_Project>
