{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: prio3_swx.py (wie Terminal)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/venv/bin/python",
            "program": "${workspaceFolder}/tools/swx-builder/prio3_swx.py",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "redirectOutput": false,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "SWX_PROGRESSBAR_NOTEBOOK_NATIVE": "1"
            }
        },
        {
            "name": "Python: prio3_swx.py (owner-draw Test)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/venv/bin/python",
            "program": "${workspaceFolder}/tools/swx-builder/prio3_swx.py",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "redirectOutput": false,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "SWX_PROGRESSBAR_FORCE_OWNERDRAW": "1",
                "SWX_PROGRESSBAR_NOTEBOOK_NATIVE": "0"
            }
        },
        {
            "name": "Python: Aktuelles File debuggen (SimpleWx)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/venv/bin/python",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "redirectOutput": false,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
            }
        },
        {
            "name": "Python: Aktuelles File debuggen (Wayland)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/venv/bin/python",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "redirectOutput": false,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
            }
        }
    ]
}
